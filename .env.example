# ── Local development (LocalStack) ────────────────────────────────────────────
# Copy this file to .env.local and run: npm run infra:up && node scripts/setup-local-aws.js

# LocalStack endpoint — all AWS SDK calls point here during local development
# For real AWS deployment, remove this line and set real credentials below
AWS_ENDPOINT_URL=http://localhost:4566

AWS_REGION=us-east-1

# LocalStack accepts any non-empty string for credentials
# For real AWS: replace with your actual IAM credentials
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SNS Topic ARN — created automatically by scripts/setup-local-aws.js
# For real AWS: create the topic via console/CDK and paste the ARN here
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:shopflow-orders

# SQS Queue URLs — created automatically by scripts/setup-local-aws.js
INVENTORY_QUEUE_URL=http://localhost:4566/000000000000/shopflow-inventory-queue
PAYMENT_QUEUE_URL=http://localhost:4566/000000000000/shopflow-payment-queue
NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/shopflow-notification-queue
AUDIT_QUEUE_URL=http://localhost:4566/000000000000/shopflow-audit-queue

# Dead Letter Queue URLs
INVENTORY_DLQ_URL=http://localhost:4566/000000000000/shopflow-inventory-dlq
PAYMENT_DLQ_URL=http://localhost:4566/000000000000/shopflow-payment-dlq
NOTIFICATION_DLQ_URL=http://localhost:4566/000000000000/shopflow-notification-dlq
AUDIT_DLQ_URL=http://localhost:4566/000000000000/shopflow-audit-dlq

# DynamoDB table names
ORDERS_TABLE=shopflow-orders
INVENTORY_TABLE=shopflow-inventory
EVENTS_TABLE=shopflow-events

# Order service HTTP port
ORDER_SERVICE_PORT=3000
